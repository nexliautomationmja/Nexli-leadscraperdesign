# SUPABASE: Required for authentication and database storage
# Get your URL and anon key from https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL="YOUR_SUPABASE_PROJECT_URL"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# APIFY_TOKEN: Required for Apify lead scraper API calls.
# Get your token from https://console.apify.com/account/integrations
APIFY_TOKEN="YOUR_APIFY_TOKEN"

# ANTHROPIC_API_KEY: Required for AI-powered email generation.
# Get your key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="YOUR_ANTHROPIC_API_KEY"

# INSTANTLY_API_KEY: Required for email sending and tracking.
# Get your key from https://app.instantly.ai/app/settings/integrations/api
INSTANTLY_API_KEY="YOUR_INSTANTLY_API_KEY"

# FROM_EMAIL: Email address to send from (RECOMMENDED: use subdomain to protect main domain)
# Examples: justine@outreach.nexli.com, justine@mail.nexli.com
# Default: justine@nexli.com
FROM_EMAIL="justine@outreach.nexli.com"

# FROM_NAME: Display name for the sender
# Default: Justine
FROM_NAME="Justine"

# VITE_GOOGLE_MAPS_API_KEY: Required for Google ratings and reviews
# Get your key from https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"

# APP_URL: The URL where this app is hosted.
APP_URL="MY_APP_URL"
